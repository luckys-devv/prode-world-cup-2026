# .npmrc - Configuración de pnpm
#
# node-linker=hoisted:
#   Por defecto pnpm usa una estructura "symlinked" para node_modules.
#   React Native (y Expo) necesitan que node_modules esté "aplanado"
#   (como lo hace npm/yarn). Esta opción le dice a pnpm que instale
#   los paquetes de forma "hoisted" (aplanada) para compatibilidad.
#
# shamefully-hoist=true:
#   Alternativa más agresiva a node-linker=hoisted. NO la usamos porque
#   node-linker=hoisted es suficiente y más controlado.

# Bloquear paquetes publicados hace menos de 24 horas (1440 minutos).
# Protege contra ataques supply-chain con versiones maliciosas recién publicadas.
minimum-release-age=1440

# Bloquear subdependencias que vengan de URLs exóticas (git, http, etc.)
# en vez del registry oficial de npm.
block-exotic-subdeps=true

node-linker=hoisted