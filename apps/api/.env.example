# ═══════════════════════════════════════
# BASE DE DATOS
# ═══════════════════════════════════════
# URL de conexión a PostgreSQL
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
DATABASE_URL=postgresql://postgres:password@localhost:5432/prode_db

# ═══════════════════════════════════════
# AUTENTICACIÓN (JWT)
# ═══════════════════════════════════════
# Secreto para firmar access tokens (30 min de vida)
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu-secreto-super-seguro-cambiar-en-produccion

# Secreto para firmar refresh tokens (30 días de vida)
# DEBE SER DIFERENTE al JWT_SECRET
JWT_REFRESH_SECRET=otro-secreto-diferente-cambiar-en-produccion

# ═══════════════════════════════════════
# API DE FÚTBOL
# ═══════════════════════════════════════
# Tu API key de football-data.org
# Registrate gratis en: https://www.football-data.org/client/register
FOOTBALL_API_KEY=tu-api-key-aqui

# ═══════════════════════════════════════
# EMAILS
# ═══════════════════════════════════════
# API key de Resend para enviar emails de invitación
# Registrate en: https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email desde el cual se envían las invitaciones
EMAIL_FROM=prode@tu-dominio.com

# ═══════════════════════════════════════
# SERVIDOR
# ═══════════════════════════════════════
PORT=3001
NODE_ENV=development

# URL base del frontend (para links en emails)
FRONTEND_URL=http://localhost:8081